FROM node:22-slim AS build
WORKDIR /app

RUN corepack enable

# Copy everything (filtered by .dockerignore)
COPY . .

# Install and build
RUN yarn install --frozen-lockfile
ARG VITE_API_URL=http://localhost:4000/graphql
ENV VITE_API_URL=$VITE_API_URL
ENV NODE_OPTIONS="--max-old-space-size=4096"
RUN yarn build:platform

# Serve with nginx
FROM nginx:alpine
COPY --from=build /app/apps/platform/bundle-platform /usr/share/nginx/html
COPY nginx.compose.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
